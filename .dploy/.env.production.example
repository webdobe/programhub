# dploy production secrets — copy to `.env.production.dploy` and fill in.
# This file is sourced by .dploy/scripts/lib/env.sh before any production
# deploy/capture/restore script runs. The values mirror the GitHub Actions
# secrets/variables in `.github/workflows/deploy.yml`.

# --- Server access ---------------------------------------------------------
REMOTE_DRUPAL_HOST=your-server.com
REMOTE_DRUPAL_USER=deploy
REMOTE_DRUPAL_PATH=/srv/programhub
SSH_PRIVATE_KEY_PATH=$HOME/.ssh/id_ed25519

# --- Domains ---------------------------------------------------------------
DRUPAL_DOMAIN=api.programhub.example
NEXTJS_DOMAIN=cte.programhub.example
DRUPAL_TRUSTED_HOST=^api\.programhub\.example$

# --- Drupal ----------------------------------------------------------------
DRUPAL_HASH_SALT=
DRUPAL_DB_DATABASE=programhub
DRUPAL_DB_USERNAME=programhub
DRUPAL_DB_PASSWORD=
DRUPAL_DB_HOST=host.docker.internal
DRUPAL_DB_PORT=3306
VARNISH_SECRET=

# --- Next.js revalidation hooks --------------------------------------------
NEXT_PUBLIC_API_URL=https://api.programhub.example
NEXT_PUBLIC_SITE_URL=https://cte.programhub.example
REVALIDATE_SECRET=

# --- simple_oauth keys (PEM format, multi-line — quote with $'...\n...') ---
# Generated once with: openssl genrsa -out private.key 2048
#                      openssl rsa -in private.key -pubout -out public.key
# Paste the full PEM contents (including BEGIN/END headers).
OAUTH_PRIVATE_KEY=
OAUTH_PUBLIC_KEY=

# --- Capture/restore tunables ---------------------------------------------
# Path on the remote host where Drupal files live (mounted into containers
# at /var/www/html/web/sites/default/files and /var/www/private).
REMOTE_FILES_PUBLIC=/srv/programhub/files/public
REMOTE_FILES_PRIVATE=/srv/programhub/files/private

# Google Cloud SQL — used by capture-database.sh / restore-database.sh.
# `gcloud` and `gsutil` must be installed locally and authenticated
# (`gcloud auth login` + `gcloud config set project $GCP_PROJECT`).
#
# One-time setup for restore: grant the Cloud SQL instance's service
# account `roles/storage.objectAdmin` on the bucket. Find the SA with:
#   gcloud sql instances describe $CLOUD_SQL_INSTANCE \
#     --project=$GCP_PROJECT --format='value(serviceAccountEmailAddress)'
# IMPORTANT: no spaces around `=`, no inline comments — this file is
# `source`d by bash, so `VAR= value` runs `value` as a command.
GCP_PROJECT=
CLOUD_SQL_INSTANCE=
# Bucket name only — no gs:// prefix.
CLOUD_SQL_BUCKET=
# Path inside the bucket.
CLOUD_SQL_BUCKET_PREFIX=dploy
