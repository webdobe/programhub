{#
/**
 * @file
 * Event node view template.
 */
#}
<article{{ attributes.addClass(['ph-node', 'ph-node--event']) }}>
  <div class="ph-node__layout">
    <div class="ph-node__main">
      {% if content.field_description|render %}
        <div class="ph-node__body">{{ content.field_description }}</div>
      {% endif %}
      {% if content.field_event_url|render %}
        <div>{{ content.field_event_url }}</div>
      {% endif %}
    </div>
    <aside class="ph-node__sidebar">
      <div class="ph-node__meta">
        {{ content.field_event_type }}
        {{ content.field_location }}
        {{ content.field_duration }}
      </div>
    </aside>
  </div>
  {{ content.links }}
</article>
