{#
/**
 * @file
 * Course node view template.
 *
 * Catalog item. Main carries description + prerequisites + instructors.
 * Sidebar carries the metadata badges (number, credits, semester, year cycle).
 */
#}
<article{{ attributes.addClass(['ph-node', 'ph-node--course']) }}>
  <div class="ph-node__layout">
    <div class="ph-node__main">
      {% if content.field_description|render %}
        <div class="ph-node__body">{{ content.field_description }}</div>
      {% endif %}
      {% if content.field_course_prereqs|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Prerequisites'|t }}</h2>
          {{ content.field_course_prereqs }}
        </section>
      {% endif %}
      {% if content.field_course_rec_prereqs|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Recommended prerequisites'|t }}</h2>
          {{ content.field_course_rec_prereqs }}
        </section>
      {% endif %}
      {% if content.field_course_instructors|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Instructors'|t }}</h2>
          {{ content.field_course_instructors }}
        </section>
      {% endif %}
    </div>
    <aside class="ph-node__sidebar">
      {% if content.field_course_credits|render %}
        <div class="ph-node__stat">
          <span class="ph-node__stat-label">{{ 'Credits'|t }}</span>
          <span class="ph-node__stat-value">{{ content.field_course_credits }}</span>
        </div>
      {% endif %}
      <div class="ph-node__meta">
        {{ content.field_course_number }}
        {{ content.field_course_semester }}
        {{ content.field_course_offering }}
        {{ content.field_course_year_cycle }}
      </div>
    </aside>
  </div>
  {{ content.links }}
</article>
