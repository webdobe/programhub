{#
/**
 * @file
 * Partner institution view template.
 *
 * Profile page for a transfer-partner school. Shows hero + logo at top,
 * brief, location/type/website. The list of transfer pathways pointing at
 * this partner is rendered by a future preprocess hook (TODO) — for now
 * the partner page is the editorial profile and pathways list lives on
 * each source certificate.
 */
#}
<article{{ attributes.addClass(['ph-node', 'ph-node--partner-institution']) }}>
  {% if content.field_hero|render %}
    <div class="ph-node__hero">{{ content.field_hero }}</div>
  {% endif %}

  <div class="ph-node__layout">
    <div class="ph-node__main">
      {% if content.field_logo|render %}
        <div class="ph-node__logo">{{ content.field_logo }}</div>
      {% endif %}
      {% if content.field_description|render %}
        <div class="ph-node__body">{{ content.field_description }}</div>
      {% endif %}
    </div>
    <aside class="ph-node__sidebar">
      <div class="ph-node__meta">
        {{ content.field_institution_type }}
        {{ content.field_location }}
        {{ content.field_url }}
      </div>
    </aside>
  </div>
  {{ content.links }}
</article>
