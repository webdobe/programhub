{#
/**
 * @file
 * Graduate profile view template.
 *
 * Reuses the `.ph-node__*` shared display classes — naming is
 * historical (started as node-only), but the chrome is entity-agnostic.
 */
#}
<article{{ attributes.addClass(['ph-node', 'ph-node--profile', 'ph-node--graduate']) }}>
  {% if content.field_image|render %}
    <div class="ph-node__hero">{{ content.field_image }}</div>
  {% endif %}
  <div class="ph-node__layout">
    <div class="ph-node__main">
      {% if content.field_biography|render %}
        <div class="ph-node__body">{{ content.field_biography }}</div>
      {% endif %}
      {% if content.field_story|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Story'|t }}</h2>
          {{ content.field_story }}
        </section>
      {% endif %}
      {% if content.field_experience|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Experience'|t }}</h2>
          {{ content.field_experience }}
        </section>
      {% endif %}
      {% if content.field_skills|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Skills'|t }}</h2>
          {{ content.field_skills }}
        </section>
      {% endif %}
      {% if content.field_projects|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Projects'|t }}</h2>
          {{ content.field_projects }}
        </section>
      {% endif %}
    </div>
    <aside class="ph-node__sidebar">
      <div class="ph-node__meta">
        {{ content.field_name }}
        {{ content.field_graduated }}
        {{ content.field_portfolio }}
        {{ content.field_email }}
        {{ content.field_linkedin }}
        {{ content.field_github }}
        {{ content.field_instagram }}
        {{ content.field_game }}
      </div>
    </aside>
  </div>
</article>
