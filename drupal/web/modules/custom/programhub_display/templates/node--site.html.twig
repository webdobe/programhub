{#
/**
 * @file
 * Site node view template.
 *
 * Renders a marketing-site card: logo, name, brief, outbound link, and the
 * list of programs the site features. The Site node itself doesn't host the
 * actual frontend (that lives at field_url in a Next.js app); this view is
 * what division landing pages and admin previews see.
 */
#}
<article{{ attributes.addClass(['ph-node', 'ph-node--site']) }}>
  {% if content.field_logo|render %}
    <div class="ph-node__hero ph-node__hero--logo">{{ content.field_logo }}</div>
  {% endif %}

  <div class="ph-node__layout">
    <div class="ph-node__main">
      {% if content.field_description|render %}
        <div class="ph-node__body">{{ content.field_description }}</div>
      {% endif %}

      {% if content.field_url|render %}
        <p class="ph-node__cta">{{ content.field_url }}</p>
      {% endif %}

      {% if content.field_programs|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Programs featured'|t }}</h2>
          {{ content.field_programs }}
        </section>
      {% endif %}
    </div>

    <aside class="ph-node__sidebar">
      <div class="ph-node__meta">
        {{ content.field_division }}
      </div>
    </aside>
  </div>

  {{ content.links }}
</article>
