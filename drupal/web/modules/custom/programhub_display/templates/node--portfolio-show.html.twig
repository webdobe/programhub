{#
/**
 * @file
 * Portfolio show node view template.
 */
#}
<article{{ attributes.addClass(['ph-node', 'ph-node--portfolio-show']) }}>
  {% if content.field_hero_image|render %}
    <div class="ph-node__hero">{{ content.field_hero_image }}</div>
  {% endif %}
  <div class="ph-node__layout">
    <div class="ph-node__main">
      {% if content.field_summary|render %}
        <div class="ph-node__body"><strong>{{ content.field_summary }}</strong></div>
      {% endif %}
      {% if content.field_description|render %}
        <div class="ph-node__body">{{ content.field_description }}</div>
      {% endif %}
      {% if content.field_concept_story|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Concept'|t }}</h2>
          {{ content.field_concept_story }}
        </section>
      {% endif %}
      {% if content.field_brand_story|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Brand'|t }}</h2>
          {{ content.field_brand_story }}
        </section>
      {% endif %}
      {% if content.field_brand_images|render %}
        <section class="ph-node__section ph-node__gallery">
          <h2 class="ph-node__section-heading">{{ 'Brand assets'|t }}</h2>
          {{ content.field_brand_images }}
        </section>
      {% endif %}
      {% if content.field_event_gallery|render %}
        <section class="ph-node__section ph-node__gallery">
          <h2 class="ph-node__section-heading">{{ 'Event gallery'|t }}</h2>
          {{ content.field_event_gallery }}
        </section>
      {% endif %}
      {% if content.field_graduates|render %}
        <section class="ph-node__section">
          <h2 class="ph-node__section-heading">{{ 'Graduates'|t }}</h2>
          {{ content.field_graduates }}
        </section>
      {% endif %}
    </div>
    <aside class="ph-node__sidebar">
      <div class="ph-node__meta">
        {{ content.field_current }}
        {{ content.field_portfolio_show_date }}
        {{ content.field_portfolio_show_url }}
        {{ content.field_pitched_by }}
        {{ content.field_logo }}
      </div>
    </aside>
  </div>
  {{ content.links }}
</article>
