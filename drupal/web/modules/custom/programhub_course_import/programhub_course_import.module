<?php

/**
 * @file
 * Hooks for ProgramHub Course Import.
 *
 * - Adds an "Import Courses" operation link on each `program` node row
 *   in admin lists. Clicking it triggers a single-program scrape+import.
 * - Hides the "Courses" local task on nodes whose bundle isn't `program`
 *   (the route already gates URL access via _entity_bundles, but Drupal
 *   doesn't carry that through to tab visibility).
 * - Self-heals course path aliases on every save (`courses/<course-number>`
 *   lowercased) — see hook_node_presave below.
 */

use Drupal\Core\Cache\CacheableMetadata;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;

/**
 * Implements hook_entity_operation().
 */
function programhub_course_import_entity_operation(EntityInterface $entity): array {
  $operations = [];

  if (
    $entity->getEntityTypeId() === 'node'
    && $entity->bundle() === 'program'
    && \Drupal::currentUser()->hasPermission('import programhub courses')
  ) {
    $operations['import_courses'] = [
      'title' => t('Import Courses'),
      'url' => Url::fromRoute(
        'programhub_course_import.import_program',
        ['node' => $entity->id()],
      ),
      'weight' => 100,
    ];
  }

  return $operations;
}

/**
 * Implements hook_menu_local_tasks_alter().
 *
 * Drop the "Courses" tab when we're not on a program node. The route already
 * blocks the URL via _entity_bundles, but local-task rendering doesn't honor
 * that, so the tab would otherwise appear on every node.
 */
function programhub_course_import_menu_local_tasks_alter(array &$data, string $route_name, ?CacheableMetadata $cacheability = NULL): void {
  if ($route_name !== 'entity.node.canonical') {
    return;
  }

  $node = \Drupal::routeMatch()->getParameter('node');
  if ($node instanceof NodeInterface && $node->bundle() === 'program') {
    return;
  }

  foreach ($data['tabs'] ?? [] as $level => $tabs) {
    if (isset($tabs['programhub_course_import.courses_tab'])) {
      unset($data['tabs'][$level]['programhub_course_import.courses_tab']);
    }
  }

  if ($cacheability) {
    $cacheability->addCacheContexts(['route']);
  }
}

/**
 * Implements hook_ENTITY_TYPE_presave() for node entities.
 *
 * Self-healing path alias for course nodes. The slug shape is
 * `<dept>-<num>-<slugified-title>`; computing it on every save means
 * UI-created and importer-created courses end up at the same URL with no
 * deploy-hook dance.
 *
 * Writes to `field_path` (a fieldable_path field), which is the canonical
 * source for these nodes — the field type maintains the core path_alias
 * entity to match. pathauto = 0 prevents pathauto's pattern from
 * overwriting our value on the same save cycle.
 */
function programhub_course_import_node_presave(NodeInterface $node): void {
  if ($node->bundle() !== 'course') {
    return;
  }
  $alias = programhub_course_import_compute_course_alias($node);
  if ($alias === '' || !$node->hasField('field_path')) {
    return;
  }
  $current = (string) ($node->get('field_path')->value ?? '');
  if ($current !== $alias) {
    $node->set('field_path', $alias);
  }
  $node->path->pathauto = 0;
}

/**
 * Compute the canonical /courses/<slug> alias for a course node.
 *
 * Slug rule: `<course-number>-<slugified-title>`. The number is the unique
 * catalog identifier and goes first; the title supplies the descriptive
 * suffix. Different importers populate titles differently — some prefix
 * the number into the title field (e.g. "CITE-118 Computer Information
 * Technology Essentials"), others use just the descriptive part
 * ("Survey of Graphic Design") — so we strip any leading number prefix
 * from the title before slugifying to avoid duplicating it in the URL.
 *
 * Returns "" when the course has no number AND no title (defensive).
 */
function programhub_course_import_compute_course_alias(NodeInterface $course): string {
  $number = $course->hasField('field_course_number')
    ? trim((string) $course->get('field_course_number')->value)
    : '';
  $title = trim((string) $course->getTitle());
  if ($number === '' && $title === '') {
    return '';
  }

  // Strip any leading "{NUMBER} " prefix the title might already carry,
  // so slugifying doesn't produce "cite-118-cite-118-...".
  $titleClean = $title;
  if ($number !== '') {
    $titleClean = preg_replace(
      '/^' . preg_quote($number, '/') . '\s+/iu',
      '',
      $title,
    ) ?? $title;
  }

  // Slugify each piece, then join.
  $numberSlug = $number === '' ? '' : _programhub_course_import_slug_part($number);
  $titleSlug = $titleClean === '' ? '' : _programhub_course_import_slug_part($titleClean);
  $slug = trim($numberSlug . '-' . $titleSlug, '-');
  return $slug === '' ? '' : '/courses/' . $slug;
}

/**
 * Slugify one segment: non-alphanum → hyphen, collapse, lowercase, trim.
 */
function _programhub_course_import_slug_part(string $s): string {
  $s = preg_replace('/[^A-Za-z0-9-]+/u', '-', $s) ?? '';
  $s = preg_replace('/-+/', '-', $s) ?? '';
  return trim(strtolower($s), '-');
}
