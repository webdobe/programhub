<?php

/**
 * @file
 * Per-group OG permission overrides.
 *
 * See `programhub/drupal/ACCESS.md` § "Per-group overrides" for the change
 * protocol. Overrides live as config entities in `config/sync/`, one file
 * per (og_role × group) pair, and are applied at access-resolution time by
 * `OgAccessOverrideDecorator`.
 *
 * Phase 1 ships the plumbing as a no-op. Phase 4 wires the actual override
 * logic and the admin UI. Until then, the bundle-level OG role permissions
 * in `og.og_role.*.yml` are the single source of truth.
 */

declare(strict_types=1);

/**
 * Implements hook_help().
 */
function og_permissions_override_help(string $route_name): ?string {
  if ($route_name === 'help.page.og_permissions_override') {
    return '<p>' .
      t('Per-group OG permission overrides. See ACCESS.md for the change protocol.') .
      '</p>';
  }
  return NULL;
}
